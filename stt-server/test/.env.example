# Local stt-server endpoint used by test/test_asr.py.
STT_TEST_LOCAL_URL=http://127.0.0.1:7000/transcribe

# Aliyun realtime ASR endpoint and credentials.
VOICE_ASR_BASE_URL=wss://dashscope.aliyuncs.com/compatible-mode/v1/realtime
VOICE_ASR_API_KEY=
VOICE_ASR_MODEL=qwen3-asr-flash-realtime

# Audio streaming options for the realtime ASR API.
VOICE_ASR_CHUNK_BYTES=3200
VOICE_ASR_CHUNK_INTERVAL_MS=40

# Test defaults.
STT_TEST_LANGUAGE=zh
STT_TEST_TIMEOUT=120
# STT_TEST_EXPECTED=

# Bailian TTS test using an already cloned voice.
VOICE_TTS_API_KEY=
# Use the cloned voice_id returned by the voice enrollment API.
# If empty, test_tts.py falls back to server/config/settings.json runtime.voice.ttsVoice.
VOICE_TTS_VOICE=
VOICE_TTS_TEXT=你好，这是一次百炼复刻音色语音合成测试。
VOICE_TTS_TIMEOUT=120
# VOICE_TTS_OUTPUT=data/output/demo.mp3

# Non-sensitive TTS defaults are read from server/config/settings.json runtime.voice:
# ttsBaseUrl, ttsModel, ttsFormat, ttsSampleRate, ttsRate, ttsVolume, ttsPitch.
