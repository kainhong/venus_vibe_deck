{
  "name": "venus-vibe-deck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Venus Vibe Deck — 移动端 AI 编程控制台",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c magenta,green \"npm:watch:client\" \"npm:dev:server\"",
    "dev:server": "npm run dev -w @venus/server",
    "watch:client": "npm run build:watch -w @venus/client",
    "build": "npm run build -w @venus/server && npm run build -w @venus/client",
    "test:speech": "npm --workspace @venus/server run test:speech --",
    "start": "npm run start -w @venus/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
