# Venus Vibe Deck environment template.
# Common non-sensitive runtime settings live in server/config/settings.json under "runtime".
# Keep this file for secrets and deployment-specific overrides.

# ───────────────────────── Access Authentication ─────────────────────────

# Password required when runtime.auth.enabled is true.
AUTH_PASSWORD=

# Optional token signing secret.
# If empty, AUTH_PASSWORD is used; set a stable random value to avoid invalidating tokens when rotating the password.
AUTH_TOKEN_SECRET=

# ───────────────────────── Voice / LLM Secrets ─────────────────────────

# Cloud ASR API key. Required when runtime.voice.useServerVoice=true and runtime.voice.asrProvider=cloud.
VOICE_ASR_API_KEY=

# OpenAI-compatible Chat Completions API key.
# Used for voice refinement and hook notification summaries.
VOICE_LLM_API_KEY=

# Default TTS provider is Edge and does not need an API key.
# Set this only when runtime.voice.ttsProvider=bailian.
# VOICE_TTS_API_KEY=

# ───────────────────────── Web Push Secrets ─────────────────────────

# VAPID private key for browser push notifications. Keep this secret.
WEB_PUSH_PRIVATE_KEY=

# VAPID public key is not secret. You may keep it in server/config/settings.json runtime.webPush.publicKey.
# Set it here only when you need a deployment-specific override.
WEB_PUSH_PUBLIC_KEY=

# ───────────────────────── Optional Runtime Overrides ─────────────────────────

# Any non-sensitive runtime setting in server/config/settings.json can still be overridden by env.
# Examples:
# HOST=127.0.0.1
# PORT=8001
# LOG_LEVEL=debug
# VENUS_DATA_DIR=/tmp/venus-vibe-deck
# VENUS_DIR_ROOTS=/Users/me/projects,/tmp
# VOICE_USE_SERVER=true
# VOICE_LLM_MODEL=qwen-plus
# HOOK_SUMMARY_MAX_CHARS=240
