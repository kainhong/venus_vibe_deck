PORT=8001
HOST=0.0.0.0
LOG_LEVEL=info

# Voice ASR provider (OpenAI Realtime-compatible WebSocket)
VOICE_USE_SERVER=false
VOICE_ASR_BASE_URL=wss://api.openai.top/v1/realtime
VOICE_ASR_API_KEY=sk-xxx
VOICE_ASR_MODEL=qwen3-asr-flash-realtime
VOICE_ASR_SAMPLE_RATE=16000
VOICE_ASR_CHUNK_BYTES=3200
VOICE_ASR_CHUNK_INTERVAL_MS=40
VOICE_ASR_TIMEOUT_MS=30000

# Voice cleanup / command extraction LLM (OpenAI-compatible Chat Completions)
VOICE_LLM_BASE_URL=https://api.openai.com/v1
VOICE_LLM_API_KEY=sk-xxx
VOICE_LLM_MODEL=gpt-4.1-mini
VOICE_LLM_TIMEOUT_MS=30000
