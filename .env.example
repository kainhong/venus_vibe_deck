# Venus Vibe Deck environment template.
# Copy this file to .env, then edit values for your machine.

# ───────────────────────── Server ─────────────────────────

# HTTP and WebSocket listen address.
# Use 0.0.0.0 when accessing from another device on the same LAN.
HOST=0.0.0.0

# HTTP and WebSocket listen port.
PORT=8001

# Server log level: debug, info, warn, error, silent.
LOG_LEVEL=info

# Runtime data directory for history and push subscriptions.
# Default: ~/.venus-vibe-deck
VENUS_DATA_DIR=

# Directory browser allowlist, comma-separated.
# Only affects the browse UI; manually typed workspace paths are still allowed.
# Default: home directory + current working directory.
VENUS_DIR_ROOTS=

# ───────────────────────── Terminal / PTY ─────────────────────────

# Default command used when no CLI config is selected.
PTY_COMMAND=bash

# Default arguments for PTY_COMMAND, space-separated.
# Example: --dangerously-skip-permissions
PTY_ARGS=

# Initial PTY size before the browser reports its real terminal size.
PTY_COLS=80
PTY_ROWS=24

# Server-side reconnect replay buffer size in bytes per session.
SCROLLBACK_BYTES=51200

# ───────────────────────── Access Authentication ─────────────────────────

# Enable password authentication before the app can be used.
# When false, the app is open to anyone who can reach HOST:PORT.
AUTH_ENABLED=false

# Password required when AUTH_ENABLED=true.
# Keep this empty only when AUTH_ENABLED=false.
AUTH_PASSWORD=

# Login validity period in days. The browser stores the signed token locally.
AUTH_TTL_DAYS=7

# Optional token signing secret.
# If empty, AUTH_PASSWORD is used; set a stable random value to avoid invalidating tokens when rotating the password.
AUTH_TOKEN_SECRET=

# ───────────────────────── Web Push / PWA Notification ─────────────────────────

# VAPID public key for browser push notifications.
WEB_PUSH_PUBLIC_KEY=

# VAPID private key for browser push notifications. Keep this secret.
WEB_PUSH_PRIVATE_KEY=

# VAPID subject, usually a mailto: address or site URL.
WEB_PUSH_SUBJECT=mailto:you@example.com

# ───────────────────────── Voice Recognition ─────────────────────────

# Use server-side voice recognition.
# false: browser-native Web Speech API.
# true: browser records audio and sends it to /api/speech/transcribe.
VOICE_USE_SERVER=false

# Server-side ASR provider.
# cloud: OpenAI-compatible realtime WebSocket provider.
# local: local stt-server compatible HTTP provider.
VOICE_ASR_PROVIDER=cloud

# Local ASR service base URL, used only when VOICE_ASR_PROVIDER=local.
VOICE_LOCAL_ASR_URL=http://127.0.0.1:7000

# Cloud ASR realtime WebSocket endpoint, used only when VOICE_ASR_PROVIDER=cloud.
VOICE_ASR_BASE_URL=wss://dashscope.aliyuncs.com/compatible-mode/v1/realtime

# Cloud ASR API key. Required for cloud mode.
VOICE_ASR_API_KEY=

# Cloud ASR model name.
VOICE_ASR_MODEL=qwen3-asr-flash-realtime

# Audio sample rate expected by the server-side ASR pipeline.
VOICE_ASR_SAMPLE_RATE=16000

# Bytes sent per realtime ASR audio chunk.
VOICE_ASR_CHUNK_BYTES=3200

# Delay between realtime ASR audio chunks in milliseconds.
VOICE_ASR_CHUNK_INTERVAL_MS=40

# ASR request timeout in milliseconds.
VOICE_ASR_TIMEOUT_MS=30000

# ───────────────────────── Voice Refinement LLM ─────────────────────────

# OpenAI-compatible Chat Completions base URL used for transcript cleanup and command extraction.
VOICE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM API key. Required when server-side voice refinement is used.
VOICE_LLM_API_KEY=

# LLM model used for transcript cleanup and command extraction.
VOICE_LLM_MODEL=qwen-plus

# LLM request timeout in milliseconds.
VOICE_LLM_TIMEOUT_MS=30000

# ───────────────────────── Text To Speech ─────────────────────────

# Enable server-side TTS endpoint /api/tts.
VOICE_TTS_ENABLED=false

# Edge TTS voice name.
VOICE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# TTS speaking rate, relative percentage such as +0%, +10%, -10%.
VOICE_TTS_RATE=+0%

# TTS volume, relative percentage such as +0%, +10%, -10%.
VOICE_TTS_VOLUME=+0%
